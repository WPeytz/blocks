{
  "name": "blocks",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Blocks — an original offline falling-block puzzle game.",
  "author": "Blocks",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "icon": "node scripts/make-icon.mjs",
    "app:dev": "node electron/dev.mjs",
    "app:build": "npm run icon && npm run build && electron-builder",
    "app:dir": "npm run icon && npm run build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.offlineblocks.game",
    "productName": "Blocks",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ],
    "mac": {
      "category": "public.app-category.games",
      "icon": "build/icon.png",
      "identity": null,
      "target": [
        "dmg",
        "dir"
      ]
    }
  }
}
